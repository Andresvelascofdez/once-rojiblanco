    "typescript": "^5.5.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.40.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.98.0"
  }
}
